# =============================================================================
# PROJECT SPECIFIC
# =============================================================================

# GitHub data cache (keep structure, but may want to ignore large files)
# github-data.json is intentionally NOT ignored as it's part of the Bronze layer

# Generated diagrams - keep PNG files as they're needed for LaTeX
# But ignore temporary diagram generation files
*.dot
*.gv

# Firebase cache and config (if using Firebase CLI)
**/.firebase
firebase-debug.log
firebase-debug.*.log

# Temporary analysis files
**/temp
**/tmp
**/scratch

# Local configuration files
local.env
config.local.*

